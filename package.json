{
  "name": "@felipesauer/mnema",
  "version": "0.5.0-alpha.0",
  "description": "A tamper-evident, local-first audit trail for AI-agent work — an MCP server giving Claude Code, Cursor and other agents typed tools behind workflow gates, with every action recorded in a SHA-256 hash-chained log.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "audit-trail",
    "tamper-evident",
    "agent-governance",
    "provenance",
    "accountability",
    "audit-log",
    "claude-code",
    "cursor",
    "task-tracker",
    "workflow",
    "sqlite",
    "local-first"
  ],
  "author": "Felipe Sauer (https://github.com/felipesauer)",
  "type": "module",
  "bin": {
    "mnema": "./dist/index.js"
  },
  "files": [
    "dist/",
    "workflows/",
    "CHANGELOG.md"
  ],
  "homepage": "https://github.com/felipesauer/mnema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipesauer/mnema.git"
  },
  "bugs": {
    "url": "https://github.com/felipesauer/mnema/issues"
  },
  "scripts": {
    "build": "tsc && tsc-alias && node scripts/copy-migrations.mjs",
    "prepack": "pnpm build",
    "prepublishOnly": "bash scripts/publish-check.sh",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prebench": "pnpm build",
    "bench": "tsx bench/cli-bench.ts",
    "bench:mcp": "tsx bench/mcp-bench.ts",
    "lint": "biome check src/ tests/ bench/",
    "lint:fix": "biome check --write src/ tests/ bench/",
    "smoke:bootstrap": "bash scripts/smoke-bootstrap.sh",
    "smoke:mcp": "tsx scripts/mcp-smoke.ts",
    "publish:check": "bash scripts/publish-check.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.34.1",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.9",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "gray-matter>js-yaml": "^4.2.0"
    }
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.8.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
