{
  "name": "mnema-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for @mnema/core and @mnema/mnema. The product package is packages/mnema.",
  "author": "Felipe Sauer (https://github.com/felipesauer)",
  "type": "module",
  "homepage": "https://felipesauer.github.io/mnema/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipesauer/mnema.git"
  },
  "bugs": {
    "url": "https://github.com/felipesauer/mnema/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @mnema/mnema dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check packages/ tests/ scripts/",
    "lint:fix": "biome check --write packages/ tests/ scripts/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "verify:docs": "node scripts/verify-docs-site.mjs",
    "prebench": "pnpm build",
    "bench": "pnpm --filter @mnema/mnema bench",
    "bench:mcp": "pnpm --filter @mnema/mnema bench:mcp",
    "bench:scale": "pnpm --filter @mnema/core bench:scale",
    "smoke:bootstrap": "bash scripts/smoke-bootstrap.sh",
    "smoke:mcp": "tsx scripts/mcp-smoke.ts",
    "publish:check": "bash scripts/publish-check.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.34.1",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "fast-check": "^4.9.0",
    "pino-pretty": "^13.1.3",
    "semver": "^7.8.5",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "gray-matter>js-yaml": "^4.2.0"
    }
  }
}
