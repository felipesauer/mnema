{
  "name": "@saurim/mnema",
  "version": "0.1.0",
  "description": "Cognitive persistence for AI agents",
  "keywords": [
    "mcp",
    "agents",
    "claude-code",
    "cursor",
    "task-tracker",
    "audit",
    "memory"
  ],
  "type": "module",
  "bin": {
    "mnema": "./dist/index.js"
  },
  "files": [
    "dist/",
    "workflows/",
    "templates/"
  ],
  "homepage": "https://github.com/saurim/mnema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saurim/mnema.git"
  },
  "bugs": {
    "url": "https://github.com/saurim/mnema/issues"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/cli-bench.ts",
    "lint": "biome check src/ tests/ bench/",
    "lint:fix": "biome check --write src/ tests/ bench/"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "semver": "^7.7.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
