{
  "name": "@saurim/mnema",
  "version": "0.1.0",
  "description": "Cognitive persistence for AI agents",
  "type": "module",
  "bin": {
    "mnema": "./dist/index.js"
  },
  "files": [
    "dist/",
    "workflows/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
